<?xml version="1.0"?>
<!--
  testbot (see testbot.urdf) plus two non-drivetrain mechanisms, used to validate the
  MECHANISM pipeline end-to-end (UrdfPostProcessor.RunBatchValidateMechanisms): the
  post-processor must find the non-wheel joints, wire a MotorActuator to the revolute
  arm and a PneumaticActuator to the prismatic piston, and both must actually move
  under edit-mode physics. Keep testbot.urdf itself untouched - its own batch
  validation asserts exactly one wheel per side and a specific drive distance.

  Additions over testbot:
    - arm: a short 0.12 x 0.04 x 0.04 m lever on a revolute joint mounted 0.25 m up
      (a virtual mast - the joint deliberately floats high above the chassis so the
      arm's whole +/-90 deg swing sphere stays clear of the sibling links: wheels,
      caster, piston; sibling-link contacts are NOT filtered by the articulation and
      an arm that sweeps through them jams instead of rotating). Swings about y
      (pitch). Neither link nor joint name contains "wheel".
    - piston: 0.05 m cube on a prismatic joint at the chassis front top, sliding
      0..0.05 m along z (up) - reads as a pneumatic cylinder to the post-processor
      (slider joints are pistons per the Fusion export conventions).
  All inertia tensors are the exact solid-primitive values for the given masses.
-->
<robot name="testbot_mech">

  <link name="base_link">
    <inertial>
      <mass value="3.0"/>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <!-- solid box m/12*(b^2+c^2) with x=0.4 y=0.3 z=0.1 -->
      <inertia ixx="0.025" ixy="0" ixz="0" iyy="0.0425" iyz="0" izz="0.0625"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
    </collision>
  </link>

  <link name="left_wheel">
    <inertial>
      <mass value="0.3"/>
      <!-- inertial frame rotated with the cylinder: izz is the spin axis term m*r^2/2,
           ixx/iyy are m*(3r^2+h^2)/12 -->
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <inertia ixx="0.00021" ixy="0" ixz="0" iyy="0.00021" iyz="0" izz="0.000375"/>
    </inertial>
    <visual>
      <!-- URDF cylinders stand along local z; roll them 90 deg about x so the
           axle lies along the joint's y axis -->
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <link name="right_wheel">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <inertia ixx="0.00021" ixy="0" ixz="0" iyy="0.00021" iyz="0" izz="0.000375"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>
  </link>

  <link name="caster">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- solid sphere 2/5*m*r^2 -->
      <inertia ixx="0.000025" ixy="0" ixz="0" iyy="0.000025" iyz="0" izz="0.000025"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
  </link>

  <!-- Lever arm: short box centered 0.06 m behind its pivot, extending rearward and
       swinging about y. Solid box m/12 terms with x=0.12 y=0.04 z=0.04. -->
  <link name="arm">
    <inertial>
      <mass value="0.3"/>
      <origin xyz="-0.06 0 0" rpy="0 0 0"/>
      <inertia ixx="0.00008" ixy="0" ixz="0" iyy="0.0004" iyz="0" izz="0.0004"/>
    </inertial>
    <visual>
      <origin xyz="-0.06 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.04 0.04"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.06 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.12 0.04 0.04"/>
      </geometry>
    </collision>
  </link>

  <!-- Piston head: small cube pushed up along z by the prismatic joint.
       Solid cube m/12*(a^2+b^2) with 0.05 sides. -->
  <link name="piston">
    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.0000833" ixy="0" ixz="0" iyy="0.0000833" iyz="0" izz="0.0000833"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- Both wheel axes point along +y (robot left), so positive rotation moves the
       tire's contact patch backward and the same positive velocity on both joints
       drives the robot forward - no per-side sign flip needed. -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0.1 0.17 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" velocity="50"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.1 -0.17 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="5" velocity="50"/>
  </joint>

  <!-- Caster contact point = -0.025 (center) - 0.025 (radius) = -0.05, the same
       height as the wheel contact patches, so the robot rests level. -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="-0.18 0 -0.025" rpy="0 0 0"/>
  </joint>

  <!-- Arm pivot on the virtual mast, 0.25 m up: the swing sphere (0.14 m around the
       pivot) clears every sibling link, so the full +/-90 deg travel is free space
       and the validator's 0.3 rad sweep assertion measures the DRIVE, not contacts. -->
  <joint name="arm_joint" type="revolute">
    <parent link="base_link"/>
    <child link="arm"/>
    <origin xyz="-0.15 0 0.25" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.5707963267948966" upper="1.5707963267948966" effort="5" velocity="10"/>
  </joint>

  <!-- Piston at the chassis front top, stroking 5 cm straight up. The 0..0.05 m
       limits become the PneumaticActuator's retracted/extended targets (x10 by the
       post-processor's scale bake). -->
  <joint name="piston_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="piston"/>
    <origin xyz="0.1 0 0.105" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0" upper="0.05" effort="50" velocity="0.5"/>
  </joint>

</robot>
